pl-6 space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Enkripsi End-to-End\"}],\": Data sensitif dienkripsi saat transit (SSL/TLS 1.3) dan saat disimpan (AES-256).\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Pusat Data Terlokalisasi\"}],\": Server kami berlokasi di Indonesia, mematuhi kedaulatan data nasional.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Kontrol Akses Ketat\"}],\": Penerapan prinsip \",[\"$\",\"em\",null,{\"children\":\"Least Privilege\"}],\" di mana hanya personel berwenang yang dapat mengakses data untuk keperluan teknis.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audit Berkala\"}],\": Kami melakukan pemindaian kerentanan dan audit keamanan secara rutin.\"]}]]}]\n1f:[\"$\",\"h3\",null,{\"children\":\"5. Pembagian Data kepada Pihak Ketiga\"}]\n20:[\"$\",\"p\",null,{\"children\":\"Kami menjunjung tinggi kerahasiaan data Anda. Data hanya dibagikan dalam konteks berikut:\"}]\n21:[\"$\",\"ul\",null,{\"className\":\"list-disc pl-6 space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Pengurus Lingkungan\"}],\": Pengurus RT/RW Anda memiliki akses ke data warga untuk keperluan administrasi internal lingkungan.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Mitra Pembayaran\"}],\": Payment Gateway berlisensi Bank Indonesia untuk memproses transaksi keuangan secara aman.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Penegak Hukum\"}],\": Jika diwajibkan oleh perintah pengadilan atau undang-undang yang berlaku.\"]}]]}]\n22:[\"$\",\"h3\",null,{\"children\":\"6. Hak-Hak Anda sebagai Subjek Data\"}]\n23:[\"$\",\"p\",null,{\"children\":\"Sesuai UU PDP, Anda berhak untuk:\"}]\n24:[\"$\",\"ul\",null,{\"className\":\"list-disc pl-6 space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Mengakses dan menda