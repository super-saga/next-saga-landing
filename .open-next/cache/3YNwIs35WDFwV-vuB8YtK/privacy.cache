ilikan properti, status hunian, dan data anggota keluarga yang didaftarkan dalam Kartu Keluarga digital di platform.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Keuangan\"}],\": Bukti pembayaran iuran dan riwayat transaksi. \",\"$L16\"]}]]}],\"$L17\",\"$L18\",\"$L19\",\"$L1a\",\"$L1b\",\"$L1c\",\"$L1d\",\"$L1e\",\"$L1f\",\"$L20\",\"$L21\",\"$L22\",\"$L23\",\"$L24\",\"$L25\",\"$L26\",\"$L27\",\"$L28\",\"$L29\"]}]]}],null,\"$L2a\"]}]\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L2b\",null,{\"children\":\"$L2c\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L2d\",null,{\"children\":[\"$\",\"$2\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L2e\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n2f:I[97367,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/3d060d449bada4c1.js\"],\"OutletBoundary\"]\n13:[\"$\",\"path\",\"mthhwq\",{\"d\":\"m9 18 6-6-6-6\"}]\n14:[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"className\":\"text-muted-foreground hover:text-primary transition-colors flex items-center gap-2 group\",\"children\":[[\"$\",\"svg\",null,{\"ref\":\"$undefined\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"width\":24,\"height\":24,\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"strokeWidth\":2,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"lucide lucide-chevron-right h-4 w-4 transition-transform group-hover:translate-x-1\",\"children\":[[\"$\",\"path\",\"mthhwq\",{\"d\":\"m9 18 6-6-6-6\"}],\"$undefined\"]}],\"Blog\"]}]}]\n15:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h4\",null,{\"className\":\"font-semibold mb-6 text-lg text-foreground relative inline-block\",\"children\":[\"Legal\",[\"$\",\"span\",null,{\"className\":\"absolute -bottom-2 left-0 w-12 h-1 bg-primary rounded-full\"}]]}],[\"$\",\"ul\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"li\",null,{\"children\":[