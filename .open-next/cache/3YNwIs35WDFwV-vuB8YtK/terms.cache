\":\\\"text-muted-foreground hover:text-primary transition-colors flex items-center gap-2 group\\\",\\\"children\\\":[[\\\"$\\\",\\\"svg\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"xmlns\\\":\\\"http://www.w3.org/2000/svg\\\",\\\"width\\\":24,\\\"height\\\":24,\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"fill\\\":\\\"none\\\",\\\"stroke\\\":\\\"currentColor\\\",\\\"strokeWidth\\\":2,\\\"strokeLinecap\\\":\\\"round\\\",\\\"strokeLinejoin\\\":\\\"round\\\",\\\"className\\\":\\\"lucide lucide-chevron-right h-4 w-4 transition-transform group-hover:translate-x-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"path\\\",\\\"mthhwq\\\",{\\\"d\\\":\\\"m9 18 6-6-6-6\\\"}],\\\"$undefined\\\"]}],\\\"Kebijakan Privasi\\\"]}]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/security\\\",\\\"className\\\":\\\"text-muted-foreground hover:text-primary transition-colors flex items-center gap-2 group\\\",\\\"children\\\":[[\\\"$\\\",\\\"svg\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"xmlns\\\":\\\"http://www.w3.org/2000/svg\\\",\\\"width\\\":24,\\\"height\\\":24,\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"fill\\\":\\\"none\\\",\\\"stroke\\\":\\\"currentColor\\\",\\\"strokeWidth\\\":2,\\\"strokeLinecap\\\":\\\"round\\\",\\\"strokeLinejoin\\\":\\\"round\\\",\\\"className\\\":\\\"lucide lucide-chevron-right h-4 w-4 transition-transform group-hover:translate-x-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"path\\\",\\\"mthhwq\\\",{\\\"d\\\":\\\"m9 18 6-6-6-6\\\"}],\\\"$undefined\\\"]}],\\\"Keamanan\\\"]}]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"16:[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"6. Larangan Penggunaan\\\"}]\\n17:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Anda setuju untuk tidak menggunakan layanan kami untuk:\\\"}]\\n18:[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"list-disc pl-6 space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Mengunggah atau menyebarkan konten yang melanggar hukum, merugikan, mengandung SARA, atau tidak etis.\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Menggunakan layanan untuk tujuan penipuan, phishing, atau pelanggaran hukum lainnya.\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Mengganggu atau merusak integritas atau keamanan sistem kami (misalnya, menyebarkan virus atau melakukan serangan DDoS).\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Mencoba mengakses data pengguna lain tanpa izin.\\\"}]]}]\\n19:[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"7. Pembayaran dan Biaya\\\"}]\\n1a:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Meskipun paket Starter Sahabat Warga gratis digunakan, layanan tertentu (seperti Paket Pro atau Business) mungkin dikenakan biaya berlangganan. Selain itu, saat memproses pembayaran iuran secara online, Anda mungkin dikenakan biaya admin oleh penyedia layanan pembayaran (Payment Gateway) pihak ketiga. Kami tidak bertanggung jawab atas biaya tambahan yang dikenakan oleh penyedia layanan pihak ketiga tersebut.\\\"}]\\n1b:[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"8. Batasan Tanggung Jawab\\\"}]\\n1c:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"PT Saga Tekno Studio tidak bertanggung jawab atas kerugian atau kerusakan apa pun yang timbul dari penggunaan layanan kami, baik langsung maupun tidak langsung, insidental, atau konsekuensial. Layanan kami disediakan \\\\\\\"apa adanya\\\\\\\" dan \\\\\\\"sebagaimana tersedia\\\\\\\" tanpa jaminan apa pun, baik tersurat maupun tersirat, termasuk jaminan ketersediaan layanan tanpa gangguan.\\\"}]\\n1d:[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"9. Perubahan Syarat\\\"}]\\n1e:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Kami dapat memperbarui Syarat dan Ketentuan ini dari waktu ke waktu untuk mencerminkan perubahan dalam praktik kami, fitur layanan, atau untuk mematuhi peraturan yang berlaku. Perubahan akan berlaku segera setelah diposting di situs ini. Penggunaan Anda yang berkelanjutan atas situs setelah perubahan tersebut dianggap sebagai penerimaan Anda atas perubahan tersebut.\\\"}]\\n1f:[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"10. Hukum yang Berlaku\\\"}]\\n20:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Syarat dan Ketentuan ini diatur oleh dan ditafsirkan sesuai dengan hukum yang berlaku di Negara Republik Indonesia. Setiap perselisihan yang timbul dari atau terkait dengan Syarat dan Ketentuan ini akan diselesaikan di pengadilan yang berwenang di Indonesia.\\\"}]\\n21:[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"11. Hubungi Kami\\\"}]\\n22:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Jika Anda memiliki pertanyaan atau kekhawatiran tentang Syarat dan Ketentuan ini, atau tentang layanan kami, silakan hubungi kami di \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"legal@saga.co.id\\\"}],\\\".\\\"]}]\\n23:[\\\"$\\\",\\\"$L28\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$2\\\",null,{\\\"name\\\":\\\"Next.MetadataOutlet\\\",\\\"children\\\":\\\"$@29\\\"}]}]\\n\"])</script><script>self.__next_f.push([1,\"25:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1\\\"}]]\\n\"])</script><script>self.__next_f.push([1,\"2a:I[27201,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/3d060d449bada4c1.js\\\"],\\\"IconMark\\\"]\\n\"])</script><script>self.__next_f.push([1,\"27:[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Sahabat Warga by Saga\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Solusi Manajemen Lingkungan Modern\\\"}],[\\\"$\\\",\\\"link\\\",\\\"2\\\",{\\\"rel\\\":\\\"manifest\\\",\\\"href\\\":\\\"/manifest.webmanifest\\\",\\\"crossOrigin\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"link\\\",\\\"3\\\",{\\\"rel\\\":\\\"canonical\\\",\\\"href\\\":\\\"https://saga.co.id\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"4\\\",{\\\"property\\\":\\\"og:title\\\",\\\"content\\\":\